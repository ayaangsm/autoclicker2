<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0c0f"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☑ CHECKBOX CLICKER"
            android:textColor="#00e5ff"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Floating Auto-Clicker"
            android:textColor="#4a6070"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="28dp"/>

        <!-- Step 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0f1318"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STEP 1 — ACCESSIBILITY"
                android:textColor="#00e5ff"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvAccessibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking..."
                android:textSize="13sp"
                android:fontFamily="monospace"/>

            <Button
                android:id="@+id/btnAccessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN ACCESSIBILITY SETTINGS"
                android:backgroundTint="#00e5ff"
                android:textColor="#0a0c0f"
                android:fontFamily="monospace"
                android:layout_marginTop="10dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Step 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0f1318"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STEP 2 — OVERLAY PERMISSION"
                android:textColor="#00e5ff"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking..."
                android:textSize="13sp"
                android:fontFamily="monospace"/>

            <Button
                android:id="@+id/btnOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GRANT OVERLAY PERMISSION"
                android:backgroundTint="#00e5ff"
                android:textColor="#0a0c0f"
                android:fontFamily="monospace"
                android:layout_marginTop="10dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Step 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0f1318"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STEP 3 — FLOATING BUTTON"
                android:textColor="#00e5ff"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A CLICK button will float over all apps.\nTap it to instantly click all checkboxes.\nDrag it to reposition."
                android:textColor="#8aabb0"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnToggleFloat"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="▶ SHOW FLOATING BUTTON"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#00cc55"
                android:fontFamily="monospace"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
